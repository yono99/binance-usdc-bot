# ============================================================
#  MODE: dry  | test | live
#   dry  = tanpa API key, simulasi penuh (default, aman)
#   test = Binance Futures TESTNET (uang palsu, API key testnet)
#   live = UANG NYATA. Jangan diisi sebelum kamu yakin di test.
# ============================================================
MODE=dry

# --- Binance Futures TESTNET keys (mode=test) ---
# Daftar di https://testnet.binancefuture.com  -> API Key
BINANCE_TEST_KEY=
BINANCE_TEST_SECRET=

# --- Binance Futures LIVE keys (mode=live) ---
# WAJIB: aktifkan "Enable Futures" saja. JANGAN aktifkan withdrawal.
# WAJIB: kunci API ke IP server kamu (IP whitelist).
BINANCE_LIVE_KEY=
BINANCE_LIVE_SECRET=

# --- Gemini (opsional, layer konfirmasi/veto) ---
# Boleh banyak key dipisah koma untuk rotasi.
GEMINI_API_KEYS=
GEMINI_ENABLED=false
