# ============================================================
#  Binance USDC-M Futures Bot — Hybrid Rust core + Python services
#  Arsitektur:
#    [Rust core]  WS ingestion · data normalize · risk gate · execution
#    [Python svc] screening · smart rotate · signal engine · Gemini
#    IPC: ZeroMQ (default) atau gRPC
#  Copy ke .env lalu isi sesuai mode. JANGAN commit .env.
# ============================================================

# -------------------- GLOBAL --------------------
# dry | test | live
#   dry  = data publik nyata, order disimulasi (tanpa key) — PAKAI INI untuk paper
#   test = sama dgn dry (Binance futures TESTNET sudah DEPRECATED) — paper di data live
#   live = UANG NYATA
MODE=dry

# Pasangan margin & timeframe sinyal (override config.yaml bila diisi)
QUOTE_ASSET=USDC
SIGNAL_TIMEFRAME=15m
LOG_LEVEL=info                       # trace|debug|info|warn|error (Rust + Python)

# ============================================================
#  BINANCE API
# ============================================================
# --- TESTNET (MODE=test) — https://testnet.binancefuture.com ---
BINANCE_TEST_KEY=
BINANCE_TEST_SECRET=
BINANCE_TEST_REST=https://testnet.binancefuture.com
BINANCE_TEST_WS=wss://stream.binancefuture.com/ws

# --- LIVE (MODE=live) — Futures ON, withdrawal OFF, IP whitelist WAJIB ---
BINANCE_LIVE_KEY=
BINANCE_LIVE_SECRET=
BINANCE_LIVE_REST=https://fapi.binance.com
BINANCE_LIVE_WS=wss://fstream.binance.com/ws

# Recv window (ms) untuk signed request; jaga kecil agar tahan replay
BINANCE_RECV_WINDOW=5000

# ============================================================
#  RUST CORE  (crate: core/)  — hot path, sub-ms
# ============================================================
CORE_HOST=127.0.0.1

# Simbol futures USDC (lowercase, dipisah koma) untuk WS stream core
SYMBOLS=btcusdc,ethusdc,bnbusdc,solusdc
# Equity awal untuk sizing saat dry/test (live ambil dari akun)
START_EQUITY=1000

# WS ingestion (Layer 1) — tokio-tungstenite
WS_RECONNECT_MS=1000
WS_MAX_RECONNECT=0                   # 0 = tak terbatas
TICK_BUFFER_CAP=65536                # lock-free ring buffer (power of 2)
OHLCV_BUFFER_BARS=500

# Risk gate (Layer 5) — keputusan in-process, ambil dari config.yaml/risk
RISK_DAILY_MAX_LOSS_PCT=3.0
RISK_ACCOUNT_RISK_PCT=0.5
RISK_LEVERAGE=3
RISK_MAX_PORTFOLIO_EXPOSURE_PCT=30
RISK_DAILY_MAX_TRADES=20
RISK_SL_ATR_MULT=1.5
RISK_TP_ATR_MULT=2.6

# Execution (Layer 6)
EXEC_SLIPPAGE_GUARD_PCT=0.15
EXEC_RETRY_MAX=3
EXEC_RETRY_BACKOFF_MS=120
EXEC_ORDER_TIMEOUT_MS=2000

# ============================================================
#  IPC  —  Rust core  <->  Python services
# ============================================================
# transport: zmq | grpc
IPC_TRANSPORT=zmq

# ZeroMQ endpoints (PUB/SUB untuk market+signal, REQ/REP untuk order intent)
ZMQ_MARKET_PUB=tcp://127.0.0.1:5556  # core -> python: tick/OHLCV ternormalisasi
ZMQ_SIGNAL_PUSH=tcp://127.0.0.1:5557 # python -> core: sinyal/intent entry
ZMQ_EVENT_PUB=tcp://127.0.0.1:5558   # core -> python: fill/close/PnL event

# gRPC (dipakai bila IPC_TRANSPORT=grpc)
GRPC_CORE_ADDR=127.0.0.1:50051       # server di Rust core
GRPC_PYTHON_ADDR=127.0.0.1:50052     # callback server di Python
GRPC_TLS=false

# ============================================================
#  PYTHON SERVICES  (svc/)  — screening, rotate, signal, gemini
# ============================================================
SCREEN_REFRESH_SECONDS=300
SIGNAL_POLL_SECONDS=20
PYTHON_MAX_OPEN_POSITIONS=2

# --- Gemini (opsional; layer konfirmasi/veto regime) ---
GEMINI_ENABLED=false
GEMINI_API_KEYS=                     # banyak key dipisah koma -> rotasi
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ROLE=veto                     # confirm | veto | off
GEMINI_MIN_REGIME_SCORE=0.4

# ============================================================
#  OBSERVABILITY (opsional)
# ============================================================
# notifikasi Telegram saat open/close/likuidasi (isi keduanya untuk mengaktifkan)
# token dari @BotFather; chat_id dari @userinfobot. Test via tombol di dashboard.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
METRICS_PORT=9090                    # Prometheus exporter (Rust core)
